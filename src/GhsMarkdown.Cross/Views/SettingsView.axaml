<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GhsMarkdown.Cross.ViewModels"
             xmlns:svc="using:GhsMarkdown.Cross.Services"
             x:Class="GhsMarkdown.Cross.Views.SettingsView"
             x:DataType="vm:MainWindowViewModel">

  <ScrollViewer>
    <StackPanel Margin="12,16,12,16" Spacing="12">

      <TextBlock Text="Settings"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource text-primary}" />

      <Border Background="{DynamicResource border-subtle}" Height="1" />

      <!-- ═══ THEME ═══ -->
      <TextBlock Text="THEME"
                 FontSize="10"
                 Foreground="{DynamicResource text-hint}" />

      <StackPanel Spacing="6">
        <RadioButton x:Name="RadioDark"
                     Content="GHS Dark"
                     GroupName="GhsTheme"
                     Foreground="{DynamicResource text-primary}"
                     Command="{Binding SetThemeCommand}"
                     CommandParameter="Dark"
                     IsChecked="{Binding IsThemeDark, Mode=OneWay}" />
        <RadioButton x:Name="RadioLight"
                     Content="GHS Light"
                     GroupName="GhsTheme"
                     Foreground="{DynamicResource text-primary}"
                     Command="{Binding SetThemeCommand}"
                     CommandParameter="Light"
                     IsChecked="{Binding IsThemeLight, Mode=OneWay}" />
        <RadioButton x:Name="RadioCustom"
                     Content="GHS Custom"
                     GroupName="GhsTheme"
                     Foreground="{DynamicResource text-primary}"
                     Command="{Binding SetThemeCommand}"
                     CommandParameter="Custom"
                     IsChecked="{Binding IsThemeCustom, Mode=OneWay}" />
        <RadioButton x:Name="RadioAuto"
                     Content="Auto (OS)"
                     GroupName="GhsTheme"
                     Foreground="{DynamicResource text-primary}"
                     Command="{Binding SetThemeCommand}"
                     CommandParameter="Auto"
                     IsChecked="{Binding IsThemeAuto, Mode=OneWay}" />
      </StackPanel>

      <!-- Custom theme color editor -->
      <StackPanel IsVisible="{Binding IsThemeCustom}"
                  Margin="0,12,0,0"
                  Spacing="6">

        <TextBlock Text="CUSTOM COLORS"
                   FontSize="10" FontWeight="Bold"
                   Foreground="{DynamicResource text-hint}"
                   Margin="0,0,0,4" />

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="App Background"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="bg-shell"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Panel Background"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="bg-panel"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Toolbar Background"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="bg-toolbar"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Editor Background"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="bg-editor"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Preview Background"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="bg-preview"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Accent Color"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="accent"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Border Color"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="border"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Primary Text"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="text-primary"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Secondary Text"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="text-secondary"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Hint / Icon Color"
                     FontSize="11" Foreground="{DynamicResource text-secondary}"
                     VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1"
                       Tag="text-hint"
                       ColorChanged="OnColorPickerChanged"
                       HorizontalAlignment="Left" />
        </Grid>

        <!-- Syntax colors separator -->
        <Border Background="{DynamicResource border-subtle}" Height="1" Margin="0,8,0,4" />
        <TextBlock Text="MARKDOWN SYNTAX COLORS"
                   FontSize="10" FontWeight="Bold"
                   Foreground="{DynamicResource text-hint}"
                   Margin="0,0,0,4" />

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="H1 Color" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-h1"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="H2 Color" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-h2"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="H3 Color" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-h3"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="H4 Color" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-h4"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="H5 Color" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-h5"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="H6 Color" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-h6"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Bold Text" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-bold"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Italic Text" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-italic"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Code Color" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-code"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <Grid ColumnDefinitions="120,*" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Blockquote" FontSize="11"
                     Foreground="{DynamicResource text-secondary}" VerticalAlignment="Center" />
          <ColorPicker Grid.Column="1" Tag="syntax-blockquote"
                       ColorChanged="OnColorPickerChanged" HorizontalAlignment="Left" />
        </Grid>

        <!-- Reset buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Command="{Binding ResetCustomThemeCommand}"
                  Content="Reset to Dark"
                  FontSize="11"
                  Padding="8,4"
                  Background="Transparent"
                  BorderBrush="{DynamicResource border}"
                  BorderThickness="1"
                  CornerRadius="3"
                  Foreground="{DynamicResource text-secondary}" />
          <Button Command="{Binding ResetCustomThemeToLightCommand}"
                  Content="Reset to Light"
                  FontSize="11"
                  Padding="8,4"
                  Background="Transparent"
                  BorderBrush="{DynamicResource border}"
                  BorderThickness="1"
                  CornerRadius="3"
                  Foreground="{DynamicResource text-secondary}" />
        </StackPanel>

      </StackPanel>

      <Border Background="{DynamicResource border-subtle}" Height="1" />

      <!-- ═══ EDITOR FONT ═══ -->
      <TextBlock Text="EDITOR FONT"
                 FontSize="10"
                 Foreground="{DynamicResource text-hint}" />

      <StackPanel Spacing="6">
        <TextBlock Text="Font Family"
                   FontSize="11"
                   Foreground="{DynamicResource text-secondary}" />
        <TextBox Text="{Binding EditorFontFamily}"
                 PlaceholderText="e.g. Consolas"
                 FontSize="12"
                 Foreground="{DynamicResource text-primary}"
                 Background="{DynamicResource bg-shell}" />

        <TextBlock Text="Font Size"
                   FontSize="11"
                   Foreground="{DynamicResource text-secondary}" />
        <NumericUpDown Value="{Binding EditorFontSize}"
                       Minimum="10" Maximum="24" Increment="1"
                       FontSize="12"
                       Foreground="{DynamicResource text-primary}"
                       Background="{DynamicResource bg-shell}" />
      </StackPanel>

      <Border Background="{DynamicResource border-subtle}" Height="1" />

      <!-- ═══ AUTO-SAVE ═══ -->
      <TextBlock Text="AUTO-SAVE"
                 FontSize="10"
                 Foreground="{DynamicResource text-hint}" />

      <StackPanel Spacing="6">
        <TextBlock Text="Draft interval (seconds)"
                   FontSize="11"
                   Foreground="{DynamicResource text-secondary}" />
        <NumericUpDown Value="{Binding AutoSaveIntervalSeconds}"
                       Minimum="30" Maximum="3600" Increment="30"
                       FontSize="12"
                       FormatString="0"
                       Foreground="{DynamicResource text-primary}"
                       Background="{DynamicResource bg-shell}" />
      </StackPanel>

      <Border Background="{DynamicResource border-subtle}" Height="1" />

      <!-- ═══ SNIPPETS ═══ -->
      <TextBlock Text="SNIPPETS"
                 FontSize="10"
                 Foreground="{DynamicResource text-hint}" />

      <StackPanel Spacing="6">
        <TextBlock Text="Library path"
                   FontSize="11"
                   Foreground="{DynamicResource text-secondary}" />
        <TextBox Text="{Binding SnippetLibraryPath, Mode=OneWay}"
                 IsReadOnly="True"
                 FontSize="12"
                 Foreground="{DynamicResource text-primary}"
                 Background="{DynamicResource bg-shell}"
                 PlaceholderText="(default)" />
        <Button x:Name="BrowseSnippetPathBtn"
                Content="Browse…"
                FontSize="11"
                Foreground="{DynamicResource text-secondary}"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Left" />
      </StackPanel>

      <Border Background="{DynamicResource border-subtle}" Height="1" />

      <!-- ═══ AI ASSIST ═══ -->
      <TextBlock Text="AI ASSIST"
                 FontSize="10"
                 FontWeight="Bold"
                 Foreground="{DynamicResource text-hint}"
                 Margin="0,4,0,6" />

      <StackPanel Spacing="6">
        <TextBlock Text="Anthropic API Key"
                   FontSize="11"
                   Foreground="{DynamicResource text-secondary}"
                   Margin="0,0,0,4" />
        <TextBox Text="{Binding AnthropicApiKey}"
                 PlaceholderText="sk-ant-..."
                 PasswordChar="&#x2022;"
                 FontSize="12"
                 Foreground="{DynamicResource text-primary}"
                 Background="{DynamicResource bg-shell}"
                 Padding="6,4" />

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
          <Button Command="{Binding TestApiKeyCommand}"
                  Content="Test Connection"
                  FontSize="11"
                  Padding="8,4"
                  Background="Transparent"
                  BorderBrush="{DynamicResource border}"
                  BorderThickness="1"
                  CornerRadius="3"
                  Foreground="{DynamicResource accent}" />
          <TextBlock Text="{Binding ApiKeyStatus}"
                     FontSize="11"
                     Foreground="{DynamicResource text-hint}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock FontSize="10"
                   Foreground="{DynamicResource text-hint}"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0">
          Get your API key at console.anthropic.com.
          Stored locally — never sent anywhere except Anthropic's API.
        </TextBlock>
      </StackPanel>

      <Border Background="{DynamicResource border-subtle}" Height="1" />

      <!-- ═══ KEYBOARD SHORTCUTS ═══ -->
      <TextBlock Text="KEYBOARD SHORTCUTS"
                 FontSize="10"
                 Foreground="{DynamicResource text-hint}" />

      <ItemsControl ItemsSource="{Binding ShortcutCommands}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type svc:CommandDescriptor}">
            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
              <TextBlock Grid.Column="0"
                         Text="{Binding Title}"
                         FontSize="12"
                         Foreground="{DynamicResource text-primary}" />
              <TextBlock Grid.Column="1"
                         Text="{Binding KeyboardShortcut}"
                         FontSize="11"
                         FontFamily="Cascadia Code,Consolas,monospace"
                         Foreground="{DynamicResource text-hint}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>

</UserControl>
