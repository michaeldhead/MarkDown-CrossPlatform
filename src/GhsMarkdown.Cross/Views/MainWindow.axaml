<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GhsMarkdown.Cross.ViewModels"
        xmlns:views="using:GhsMarkdown.Cross.Views"
        xmlns:ae="using:AvaloniaEdit"
        x:Class="GhsMarkdown.Cross.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        Background="{DynamicResource bg-shell}"
        ExtendClientAreaToDecorationsHint="False"
        DragDrop.AllowDrop="True"
        Icon="avares://GhsMarkdown.Cross/Assets/icon.ico">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewFileCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFileCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveFileAsCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding SetViewModeEditCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding SetViewModeSplitCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+W" Command="{Binding SetViewModePreviewCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenPaletteCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding PrintCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding ToggleFocusModeCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+B" Command="{Binding ToggleFormattingToolbarCommand}" />
    <KeyBinding Gesture="Ctrl+D" Command="{Binding DetachPreviewCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+X" Command="{Binding FormatStrikethroughCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+U" Command="{Binding FormatUnorderedListCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding FormatOrderedListCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+G" Command="{Binding FormatTableCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+I" Command="{Binding FormatImageCommand}" />
    <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
    <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}" />
    <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
  </Window.KeyBindings>

  <Window.Styles>

    <!-- Icon Rail button base -->
    <Style Selector="Button.icon-rail-btn">
      <Setter Property="Width" Value="44" />
      <Setter Property="Height" Value="44" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource text-hint}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.icon-rail-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource accent-dim}" />
      <Setter Property="TextElement.Foreground" Value="{DynamicResource accent}" />
    </Style>
    <!-- Background: ContentPresenter approach works correctly, keep it -->
    <Style Selector="Button.icon-rail-btn.active /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource accent-dim}" />
    </Style>

    <!-- Focus Mode toggle -->
    <Style Selector="ToggleButton.focus-toggle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Height" Value="26" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ToggleButton.focus-toggle:checked">
      <Setter Property="Background" Value="{DynamicResource accent}" />
    </Style>
    <Style Selector="ToggleButton.focus-toggle:checked > TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Pull tab -->
    <Style Selector="Button.pull-tab">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="44" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource accent-dim}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4,0,0,4" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- Tab item -->
    <Style Selector="Border.tab-item">
      <Setter Property="MinWidth" Value="80" />
      <Setter Property="MaxWidth" Value="200" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource bg-panel}" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
      <Setter Property="BorderBrush" Value="{DynamicResource border}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Border.tab-item.tab-active">
      <Setter Property="Background" Value="{DynamicResource bg-editor}" />
    </Style>

    <Style Selector="Border.tab-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource bg-shell}" />
    </Style>

  </Window.Styles>

  <Grid>
  <DockPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <!-- ═══ TITLEBAR (38px) ═══ -->
    <Border DockPanel.Dock="Top"
            Height="38"
            Background="{DynamicResource bg-toolbar}"
            BorderBrush="{DynamicResource border}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- Col 0: App name -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0"
                    Spacing="0">
          <TextBlock Text="GHS Markdown"
                     FontSize="12"
                     FontWeight="Medium"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource text-secondary}" />
          <Border Width="1" Height="16"
                  Background="{DynamicResource border}"
                  Margin="10,0,0,0" />
        </StackPanel>

        <!-- Col 1: Tab strip -->
        <ScrollViewer Grid.Column="1"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch">
          <StackPanel Orientation="Horizontal"
                      VerticalAlignment="Stretch"
                      Spacing="0">

            <!-- Tab items -->
            <ItemsControl x:Name="TabStrip"
                          ItemsSource="{Binding Tabs}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TabViewModel}">
                  <Border Classes="tab-item"
                          Classes.tab-active="{Binding IsActive}"
                          x:Name="TabItemBorder">
                    <Panel>
                      <!-- Active accent underline -->
                      <Border Height="2"
                              VerticalAlignment="Bottom"
                              Background="{DynamicResource accent}"
                              IsVisible="{Binding IsActive}" />

                      <!-- Tab content — BL-37: Grid keeps the close button pinned
                           to the right edge while the filename column absorbs
                           extra width via star sizing with ellipsis trimming.
                           A StackPanel lets the filename push the close button
                           off-screen on long names. -->
                      <Grid VerticalAlignment="Center"
                            Margin="10,0,6,0"
                            ColumnDefinitions="Auto,*,Auto">

                        <!-- Dirty dot -->
                        <Ellipse Grid.Column="0"
                                 Width="6" Height="6"
                                 Fill="{DynamicResource accent}"
                                 IsVisible="{Binding IsDirty}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,4,0" />

                        <!-- Filename -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding DisplayName}"
                                   Foreground="{DynamicResource text-primary}"
                                   Margin="0,0,4,0" />

                        <!-- Close button -->
                        <Button Grid.Column="2"
                                Classes="icon-rail-btn"
                                Width="16" Height="16"
                                Padding="0"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Close tab"
                                Tag="{Binding}">
                          <TextBlock Text="&#x2715;"
                                     FontSize="9"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource text-hint}" />
                        </Button>

                      </Grid>
                    </Panel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- New tab button -->
            <Button Classes="icon-rail-btn"
                    x:Name="NewTabButton"
                    Width="28" Height="28"
                    Padding="0"
                    VerticalAlignment="Center"
                    Margin="2,0,0,0"
                    ToolTip.Tip="New Tab (Ctrl+T)">
              <TextBlock Text="+"
                         FontSize="16"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource text-hint}" />
            </Button>

          </StackPanel>
        </ScrollViewer>

        <!-- Col 2: Right controls -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Spacing="2">
          <Button Classes="icon-rail-btn"
                  Command="{Binding ToggleFormattingToolbarCommand}"
                  Width="NaN" Height="26" Padding="8,0"
                  ToolTip.Tip="Toggle Formatting Toolbar (Ctrl+Shift+B)">
            <TextBlock Text="&#x2261;" FontSize="14"
                       Foreground="{DynamicResource accent}" />
          </Button>
          <Border Width="1" Height="16"
                  Background="{DynamicResource border}" Margin="6,0" />
          <Button Classes="icon-rail-btn"
                  Classes.active="{Binding IsEditMode}"
                  Command="{Binding SetViewModeEditCommand}"
                  Width="NaN" Height="26" Padding="8,0"
                  ToolTip.Tip="Edit Only (Ctrl+Shift+E)">
            <TextBlock Text="Edit" FontSize="11" />
          </Button>
          <Button Classes="icon-rail-btn"
                  Classes.active="{Binding IsSplitMode}"
                  Command="{Binding SetViewModeSplitCommand}"
                  Width="NaN" Height="26" Padding="8,0"
                  ToolTip.Tip="Split (Ctrl+Shift+T)">
            <TextBlock Text="Split" FontSize="11" />
          </Button>
          <Button Classes="icon-rail-btn"
                  Classes.active="{Binding IsPreviewMode}"
                  Command="{Binding SetViewModePreviewCommand}"
                  Width="NaN" Height="26" Padding="8,0"
                  ToolTip.Tip="Preview Only (Ctrl+Shift+W)">
            <TextBlock Text="Preview" FontSize="11" />
          </Button>
          <Button Classes="icon-rail-btn"
                  Command="{Binding DetachPreviewCommand}"
                  Width="NaN" Height="26" Padding="8,0"
                  ToolTip.Tip="Detach Preview Window (Ctrl+D)">
            <TextBlock Text="&#x29C9;" FontSize="13"
                       Foreground="{DynamicResource accent}" />
          </Button>
          <Border Width="1" Height="16" Background="{DynamicResource border}" Margin="6,0" />
          <Button Classes="icon-rail-btn"
                  Command="{Binding OpenExportCommand}"
                  Width="NaN" Height="26" Padding="8,0"
                  ToolTip.Tip="Export">
            <TextBlock Text="Export&#x2026;" FontSize="11" Foreground="{DynamicResource accent}" />
          </Button>
          <Button Classes="icon-rail-btn"
                  Command="{Binding PrintCommand}"
                  Width="NaN" Height="26" Padding="8,0"
                  ToolTip.Tip="Print document (Ctrl+Shift+P)"
                  Margin="4,0,0,0">
            <TextBlock Text="Print" FontSize="11" Foreground="{DynamicResource accent}" />
          </Button>
          <Border Width="1" Height="16" Background="{DynamicResource border}" Margin="8,0" />
          <ToggleButton Classes="focus-toggle"
                        IsChecked="{Binding IsFocusModeActive, Mode=OneWay}"
                        Command="{Binding ToggleFocusModeCommand}"
                        ToolTip.Tip="Toggle Focus Mode (Ctrl+Shift+F)">
            <TextBlock Text="Focus" FontSize="11" Foreground="{DynamicResource accent}" />
          </ToggleButton>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ═══ FORMATTING TOOLBAR ═══ -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding ShowFormattingToolbar}"
            Height="34"
            Background="{DynamicResource bg-toolbar}"
            BorderBrush="{DynamicResource border}"
            BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="8,0"
                  Spacing="1">
        <!-- File operations -->
        <Button Classes="icon-rail-btn"
                Command="{Binding NewFileCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="New File (Ctrl+N)">
          <TextBlock Text="&#x271A;" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding OpenFileCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Open File (Ctrl+O)">
          <TextBlock Text="&#x2398;" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding SaveFileCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Save (Ctrl+S)">
          <TextBlock Text="&#x1F4BE;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource border}" Margin="4,0" />
        <!-- Formatting -->
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatBoldCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Bold (Ctrl+B)">
          <TextBlock Text="B" FontSize="13" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatItalicCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Italic (Ctrl+I)">
          <TextBlock Text="I" FontSize="13" FontStyle="Italic"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatStrikethroughCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Strikethrough">
          <TextBlock Text="S&#x0336;" FontSize="13"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Width="28" Height="28" Padding="0"
                x:Name="CodeBlockToolbarBtn"
                ToolTip.Tip="Insert Code Block">
          <TextBlock Text="{}{}" FontSize="13" FontFamily="Consolas,monospace"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource border}" Margin="4,0" />
        <!-- Headings -->
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatH1Command}"
                Width="32" Height="28" Padding="0"
                ToolTip.Tip="Heading 1 (Ctrl+1)">
          <TextBlock Text="H1" FontSize="11" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatH2Command}"
                Width="32" Height="28" Padding="0"
                ToolTip.Tip="Heading 2 (Ctrl+2)">
          <TextBlock Text="H2" FontSize="11" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatH3Command}"
                Width="32" Height="28" Padding="0"
                ToolTip.Tip="Heading 3 (Ctrl+3)">
          <TextBlock Text="H3" FontSize="11" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatH4Command}"
                Width="32" Height="28" Padding="0"
                ToolTip.Tip="Heading 4 (Ctrl+4)">
          <TextBlock Text="H4" FontSize="11" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource border}" Margin="4,0" />
        <!-- Lists -->
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatUnorderedListCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Unordered List">
          <TextBlock Text="&#x2261;" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatOrderedListCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Ordered List">
          <TextBlock Text="1&#x2261;" FontSize="11"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource border}" Margin="4,0" />
        <!-- Block elements -->
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatTableCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Insert Table">
          <TextBlock Text="&#x229E;" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatHRCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Horizontal Rule (Ctrl+Shift+H)">
          <TextBlock Text="&#x2014;" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatLinkCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Insert Link (Ctrl+K)">
          <TextBlock Text="&#x26D3;" FontSize="13"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding FormatImageCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Insert Image">
          <TextBlock Text="&#x1F5BC;" FontSize="13"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource border}" Margin="4,0" />
        <!-- Actions -->
        <Button Classes="icon-rail-btn"
                Command="{Binding OpenExportCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Export...">
          <TextBlock Text="&#x2197;" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <Button Classes="icon-rail-btn"
                Command="{Binding PrintCommand}"
                Width="28" Height="28" Padding="0"
                ToolTip.Tip="Print (Ctrl+Shift+P)">
          <TextBlock Text="&#x2399;" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
      </StackPanel>
    </Border>

    <!-- ═══ STATUS BAR (26px) ═══ -->
    <Border DockPanel.Dock="Bottom"
            Height="26"
            Background="{DynamicResource bg-toolbar}"
            BorderBrush="{DynamicResource border-subtle}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0"
                   x:Name="StatusText"
                   Text="{Binding StatusBarText}"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   FontSize="11"
                   Foreground="{DynamicResource text-secondary}" />
        <TextBlock Grid.Column="1"
                   Text="{Binding CurrentThemeName}"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   FontSize="11"
                   Foreground="{DynamicResource text-secondary}" />
        <views:TimelineScrubberView Grid.Column="2"
                                     DataContext="{Binding Timeline}" />
      </Grid>
    </Border>

    <!-- ═══ MAIN CONTENT AREA ═══ -->
    <!-- Col 0: Icon Rail | Col 1: Left Panel | Col 2: Center (* editor+gutter+preview) | Col 3: Right Panel | Col 4: Pull Tab -->
    <Grid ColumnDefinitions="44,Auto,*,Auto,Auto">

      <!-- Col 0: Icon Rail (44px, always visible) -->
      <Border Grid.Column="0"
              Background="{DynamicResource bg-gutter}"
              BorderBrush="{DynamicResource border}"
              BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Spacing="0">

            <Button Classes="icon-rail-btn"
                    Classes.active="{Binding IsTopologyActive}"
                    Command="{Binding ActivateIconCommand}"
                    CommandParameter="Topology"
                    ToolTip.Tip="Document Topology">
              <TextBlock Text="⬡" FontSize="16"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>

            <Button Classes="icon-rail-btn"
                    Classes.active="{Binding IsFilesActive}"
                    Command="{Binding ActivateIconCommand}"
                    CommandParameter="Files"
                    ToolTip.Tip="Files">
              <TextBlock Text="⊞" FontSize="16"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>

            <Button Classes="icon-rail-btn"
                    Classes.active="{Binding IsSnippetsActive}"
                    Command="{Binding ActivateIconCommand}"
                    CommandParameter="Snippets"
                    ToolTip.Tip="Snippet Studio">
              <TextBlock Text="❮❯" FontSize="12"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>

            <Button Classes="icon-rail-btn"
                    Classes.active="{Binding IsSearchActive}"
                    Command="{Binding ActivateIconCommand}"
                    CommandParameter="Search"
                    ToolTip.Tip="Search">
              <TextBlock Text="◎" FontSize="16"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>

          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Spacing="0">
            <Button Classes="icon-rail-btn"
                    Classes.active="{Binding IsSettingsOpen}"
                    Command="{Binding ActivateIconCommand}"
                    CommandParameter="Settings"
                    ToolTip.Tip="Settings">
              <TextBlock Text="⚙" FontSize="16"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
          </StackPanel>

        </DockPanel>
      </Border>

      <!-- Col 1: Left Panel (collapsible, 220px when open) -->
      <Border Grid.Column="1"
              Width="{Binding LeftPanelWidth}"
              Background="{DynamicResource bg-panel}"
              BorderBrush="{DynamicResource border}"
              BorderThickness="0,0,1,0"
              ClipToBounds="True">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.2" Easing="CubicEaseInOut" />
          </Transitions>
        </Border.Transitions>

        <Panel>
          <!-- Panel slot occupant — resolved via DataTemplate in App.axaml -->
          <ContentControl x:Name="LeftPanelSlot"
                          IsVisible="{Binding !IsSettingsOpen}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch" />

          <views:SettingsView x:Name="SettingsViewControl"
                              IsVisible="{Binding IsSettingsOpen}"
                              DataContext="{Binding}" />
        </Panel>
      </Border>

      <!-- Col 2: Center area — nested Grid drives editor/gutter/preview proportional split -->
      <Grid Grid.Column="2" x:Name="CenterGrid">
        <Grid.ColumnDefinitions>
          <!-- Widths are managed entirely from code-behind (UpdateCenterLayout) -->
          <ColumnDefinition Width="*" />    <!-- Editor -->
          <ColumnDefinition Width="28" />   <!-- Gutter -->
          <ColumnDefinition Width="*" />    <!-- Preview -->
        </Grid.ColumnDefinitions>

        <!-- Editor pane (pinned to GHS Dark colors — .xshd limitation, see NOTES.md) -->
        <Border Grid.Column="0"
                IsVisible="{Binding EditorPaneVisible}"
                ClipToBounds="True">
          <views:CenteringTextEditor x:Name="MarkdownEditor"
                         FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                         FontSize="13"
                         ShowLineNumbers="True"
                         WordWrap="False"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />
        </Border>

        <!-- Smart Gutter (28px) — drag-to-resize handle, sync dots, word count -->
        <Border Grid.Column="1"
                x:Name="GutterBorder"
                IsVisible="{Binding GutterVisible}"
                Background="{DynamicResource bg-gutter}"
                BorderBrush="{DynamicResource border-subtle}"
                BorderThickness="1,0,1,0"
                Cursor="SizeWestEast"
                ClipToBounds="True">
          <StackPanel VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="5">

            <!-- 7 sync thread dots -->
            <Ellipse Width="6" Height="6" Fill="{Binding GutterDotBrush}" />
            <Ellipse Width="6" Height="6" Fill="{Binding GutterDotBrush}" />
            <Ellipse Width="6" Height="6" Fill="{Binding GutterDotBrush}" />
            <Ellipse Width="6" Height="6" Fill="{Binding GutterDotBrush}" />
            <Ellipse Width="6" Height="6" Fill="{Binding GutterDotBrush}" />
            <Ellipse Width="6" Height="6" Fill="{Binding GutterDotBrush}" />
            <Ellipse Width="6" Height="6" Fill="{Binding GutterDotBrush}" />

            <!-- Word count — rotated 90° so it reads vertically in the narrow gutter -->
            <Border Margin="0,8,0,0" HorizontalAlignment="Center">
              <TextBlock Text="{Binding GutterWordCount}"
                         FontSize="8"
                         Foreground="{DynamicResource text-hint}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                <TextBlock.RenderTransform>
                  <RotateTransform Angle="90" />
                </TextBlock.RenderTransform>
              </TextBlock>
            </Border>

          </StackPanel>
        </Border>

        <!-- Preview pane — NativeWebView -->
        <Border Grid.Column="2"
                IsVisible="{Binding PreviewPaneVisible}"
                Background="{DynamicResource bg-preview}"
                ClipToBounds="True">
          <NativeWebView x:Name="PreviewWebView"
                         IsVisible="{Binding PreviewPaneVisible}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch" />
        </Border>

      </Grid>

      <!-- Col 3: Right Panel (collapsible, drag-resizable when open) -->
      <Border Grid.Column="3"
              x:Name="RightPanelBorder"
              Width="{Binding RightPanelWidth}"
              Background="{DynamicResource bg-panel}"
              BorderBrush="{DynamicResource border}"
              BorderThickness="1,0,0,0"
              ClipToBounds="True">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.2" Easing="CubicEaseInOut" />
          </Transitions>
        </Border.Transitions>

        <Grid ColumnDefinitions="6,*">

          <!-- Drag handle (left edge of right panel) -->
          <Border Grid.Column="0"
                  x:Name="RightPanelDivider"
                  Background="{DynamicResource bg-gutter}"
                  BorderBrush="{DynamicResource border-subtle}"
                  BorderThickness="0,0,1,0"
                  Cursor="SizeWestEast" />

          <!-- Panel content -->
          <DockPanel Grid.Column="1">
            <!-- Slot Switcher (36px, bottom) -->
            <Border DockPanel.Dock="Bottom"
                    Height="36"
                    Background="{DynamicResource bg-toolbar}"
                    BorderBrush="{DynamicResource border}"
                    BorderThickness="0,1,0,0">
              <Grid ColumnDefinitions="*,*,*">
                <Button Grid.Column="0"
                        Classes="icon-rail-btn"
                        Classes.active="{Binding IsOutlineSlotActive}"
                        Command="{Binding SwitchToOutlineCommand}"
                        Height="36" Width="NaN"
                        HorizontalAlignment="Stretch"
                        ToolTip.Tip="Outline">
                  <TextBlock Text="OUTLINE" FontSize="9"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="1"
                        Classes="icon-rail-btn"
                        Classes.active="{Binding IsSnippetsSlotActive}"
                        Command="{Binding SwitchToSnippetsCommand}"
                        Height="36" Width="NaN"
                        HorizontalAlignment="Stretch"
                        ToolTip.Tip="Snippets">
                  <TextBlock Text="SNIPPETS" FontSize="9"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="2"
                        Classes="icon-rail-btn"
                        Classes.active="{Binding IsAiAssistSlotActive}"
                        Command="{Binding SwitchToAiAssistCommand}"
                        Height="36" Width="NaN"
                        HorizontalAlignment="Stretch"
                        ToolTip.Tip="AI Assist">
                  <TextBlock Text="AI ASSIST" FontSize="9"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
              </Grid>
            </Border>

            <!-- Slot content (fills remaining space) -->
            <ContentControl x:Name="RightPanelSlot"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
          </DockPanel>

        </Grid>
      </Border>

      <!-- Col 4: Pull Tab (10px × 44px strip) -->
      <Border Grid.Column="4"
              Background="{DynamicResource bg-gutter}"
              BorderBrush="{DynamicResource border}"
              BorderThickness="1,0,0,0">
        <Button Classes="pull-tab"
                Command="{Binding ToggleRightPanelCommand}"
                VerticalAlignment="Center"
                Width="16"
                ToolTip.Tip="{Binding RightPanelSlotName}">
          <Panel>
            <TextBlock Text="&#x203A;"
                       IsVisible="{Binding IsRightPanelOpen}"
                       FontSize="16" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource accent}" />
            <TextBlock Text="&#x2039;"
                       IsVisible="{Binding !IsRightPanelOpen}"
                       FontSize="16" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource accent}" />
          </Panel>
        </Button>
      </Border>

    </Grid>

  </DockPanel>

  <!-- ═══ EXPORT PANEL OVERLAY (ZIndex=50, right-aligned) ═══ -->
  <Border ZIndex="50"
          Grid.ColumnSpan="99"
          HorizontalAlignment="Right"
          Width="380"
          IsVisible="{Binding ExportPanel.IsOpen, FallbackValue=False}"
          BorderBrush="#222222"
          BorderThickness="1,0,0,0">
    <views:ExportPanelView DataContext="{Binding ExportPanel}" />
  </Border>

  <!-- ═══ COMMAND PALETTE OVERLAY (ZIndex=100) ═══ -->
  <!-- FallbackValue=False ensures overlay is hidden before DataContext resolves.
       Grid spans ensure full window coverage regardless of root Grid structure. -->
  <ContentControl Content="{Binding CommandPalette}"
                  IsVisible="{Binding CommandPalette.IsOpen, FallbackValue=False}"
                  ZIndex="100"
                  Grid.Row="0" Grid.RowSpan="99"
                  Grid.Column="0" Grid.ColumnSpan="99"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch" />
  </Grid>

</Window>
