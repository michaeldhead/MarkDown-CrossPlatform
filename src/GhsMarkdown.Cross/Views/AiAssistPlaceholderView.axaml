<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GhsMarkdown.Cross.ViewModels"
             x:Class="GhsMarkdown.Cross.Views.AiAssistPlaceholderView"
             x:DataType="vm:AiAssistPlaceholderViewModel">
  <TextBlock Text="{Binding PanelName}"
             Foreground="{DynamicResource text-secondary}"
             FontSize="13"
             HorizontalAlignment="Center"
             VerticalAlignment="Center" />
</UserControl>
